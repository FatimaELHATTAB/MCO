from pathlib import Path


class SQLLoader:
    def __init__(self, sql_dir: str):
        self.sql_dir = Path(sql_dir)

    def load(self, filename: str) -> str:
        path = self.sql_dir / filename
        return path.read_text(encoding="utf-8")


