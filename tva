from __future__ import annotations
import polars as pl

from repos import TableCfg
from engine import PrioritizationEngine

class PrioritizationService:
    def __init__(self, engine: PrioritizationEngine, tables: list[TableCfg]) -> None:
        self.engine = engine
        self.tables = tables

    def run(self, matching_df: pl.DataFrame) -> pl.DataFrame:
        return self.engine.run_all(matching_df, self.tables)


