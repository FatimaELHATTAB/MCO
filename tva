import polars as pl

from lifecycle_impact_service import LifecycleImpactService


def _run_update_matching(self, task):
    processor = self.create_processor()

    provider_runner = ProviderRunner(
        processor.db,
        provider=task.source,
        job_execution_id=task.job_execution_id,
    )

    countries = provider_runner.run_countries(task.source)

    for country in countries:
        tpn_insertion = TpnInsertion(
            processor.db,
            processor.logger,
            provider_runner.cfg,
        )

        # Nouvelle méthode à créer si aujourd'hui provider_runner.run()
        # fait déjà le matching directement.
        df_normalized = provider_runner.load_normalized_only(country)

        df_create = df_normalized.filter(pl.col("updated_at").is_null())
        df_update = df_normalized.filter(pl.col("updated_at").is_not_null())

        replay_input = df_normalized

        if not df_update.is_empty():
            impact_service = LifecycleImpactService(
                db=processor.db,
                schema=provider_runner.cfg.schema,
                replay_sources=["RMPM"],
            )

            impact = impact_service.prepare_update_matching(df_update)

            replay_input = impact_service.build_replay_input(
                df_updates=df_normalized,
                replay_members=impact["replay_members"],
            )

        # Important: ici le matching doit recharger l'identity après close.
        df_matched, df_not_matched, df_identity = provider_runner.run_matching_from_normalized(
            country=country,
            df_normalized=replay_input,
            df_identity=None,
        )

        tpn_insertion.process_immatriculation(df_not_matched)

        MatchingTable(processor.db).process_matching(
            df_matched,
            task.source,
            tpn_insertion,
            country,
        )



