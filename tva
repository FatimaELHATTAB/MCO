from domain.task import Task
from repositories.sql_loader import SQLLoader


class TaskRepository:
    def __init__(self, db_client, sql_loader: SQLLoader):
        self.db_client = db_client
        self.sql_loader = sql_loader

    def claim_next_pending_matching_task(self) -> Task | None:
        query = self.sql_loader.load("claim_next_pending_matching.sql")
        row = self.db_client.fetch_one(query)

        if row is None:
            return None

        return self._to_task(row)

    def mark_done(self, row_id: int) -> None:
        query = self.sql_loader.load("mark_task_done.sql")
        self.db_client.execute(query, {"row_id": row_id})

    def mark_failed(self, row_id: int, error_message: str) -> None:
        query = self.sql_loader.load("mark_task_failed.sql")
        self.db_client.execute(
            query,
            {
                "row_id": row_id,
                "error_message": error_message[:1000],
            },
        )

    def _to_task(self, row: dict) -> Task:
        payload = row.get("payload") or {}

        return Task(
            row_id=row["row_id"],
            task_type=row["task_type"],
            payload=payload,
            status=row["status"],
            created_at=row["created_at"],
            updated_at=row.get("updated_at"),
            completed_at=row.get("completed_at"),
        )


