# lifecycle_impact_service.py

import polars as pl

from lifecycle_impact_repository import (
    LifecycleAction,
    LifecycleImpactRepository,
)


class LifecycleImpactService:
    def __init__(self, db, schema: str, replay_sources: list[str] | None = None):
        self.db = db
        self.schema = schema
        self.replay_sources = replay_sources or ["RMPM"]

        self.repo = LifecycleImpactRepository(
            db=self.db,
            schema=self.schema,
        )

    def prepare_update_matching(self, df_updates):
        """
        Prépare les updates avant le matching normal.

        Rôle:
        - retrouver les tpn_id existants
        - trouver les clusters impactés
        - marquer les membres à rejouer
        - fermer ancien matching
        - fermer anciennes cluster_stats

        Ne fait PAS:
        - process_immatriculation_update
        - matching
        - insert des nouvelles données
        """

        if df_updates is None or len(df_updates) == 0:
            return self._empty_result()

        df_with_tpn = self.repo.resolve_existing_tpn(df_updates)

        if df_with_tpn is None or len(df_with_tpn) == 0:
            return self._empty_result()

        impacted_clusters = self.repo.load_impacted_clusters(df_with_tpn)

        replay_members = self.repo.load_members_for_replay(
            impacted_clusters_df=impacted_clusters,
            replay_sources=self.replay_sources,
        )

        self.repo.close_matching_for_clusters(
            impacted_clusters_df=impacted_clusters,
            action=LifecycleAction.UPDATE_MATCHING,
        )

        self.repo.close_cluster_stats(
            impacted_clusters_df=impacted_clusters,
            action=LifecycleAction.UPDATE_MATCHING,
        )

        return {
            "updates_with_tpn": df_with_tpn,
            "impacted_clusters": impacted_clusters,
            "replay_members": replay_members,
        }

    def prepare_delete(self, df_delete):
        """
        Prévu pour plus tard.
        Même logique, mais action=DELETE.
        """

        if df_delete is None or len(df_delete) == 0:
            return self._empty_result()

        df_with_tpn = self.repo.resolve_existing_tpn(df_delete)

        if df_with_tpn is None or len(df_with_tpn) == 0:
            return self._empty_result()

        impacted_clusters = self.repo.load_impacted_clusters(df_with_tpn)

        replay_members = self.repo.load_members_for_replay(
            impacted_clusters_df=impacted_clusters,
            replay_sources=self.replay_sources,
        )

        self.repo.close_matching_for_clusters(
            impacted_clusters_df=impacted_clusters,
            action=LifecycleAction.DELETE,
        )

        self.repo.close_cluster_stats(
            impacted_clusters_df=impacted_clusters,
            action=LifecycleAction.DELETE,
        )

        return {
            "delete_with_tpn": df_with_tpn,
            "impacted_clusters": impacted_clusters,
            "replay_members": replay_members,
        }

    def build_replay_input(self, df_updates, replay_members):
        """
        Construit l'input qui repassera dans le matching normal.

        Aujourd'hui:
        - updates entrants
        - + anciens membres RMPM du cluster impacté

        Attention:
        replay_members vient de matching, donc selon ton modèle,
        il faudra peut-être le reformater pour avoir les mêmes colonnes
        que df_updates.
        """

        if replay_members is None or len(replay_members) == 0:
            return df_updates

        if isinstance(df_updates, pl.DataFrame):
            replay_members = self._align_columns_polars(
                base_df=df_updates,
                other_df=replay_members,
            )
            return pl.concat([df_updates, replay_members], how="vertical_relaxed").unique()

        # fallback pandas
        import pandas as pd

        replay_members = replay_members.reindex(columns=df_updates.columns)
        return pd.concat([df_updates, replay_members], ignore_index=True).drop_duplicates()

    def _align_columns_polars(self, base_df: pl.DataFrame, other_df):
        if not isinstance(other_df, pl.DataFrame):
            other_df = pl.from_pandas(other_df)

        missing_cols = [col for col in base_df.columns if col not in other_df.columns]

        for col in missing_cols:
            other_df = other_df.with_columns(pl.lit(None).alias(col))

        return other_df.select(base_df.columns)

    def _empty_result(self):
        return {
            "updates_with_tpn": None,
            "impacted_clusters": None,
            "replay_members": None,
        }


