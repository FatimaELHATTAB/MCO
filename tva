from __future__ import annotations
from fastapi import FastAPI
import polars as pl

from api.schemas import PrioritizeRequest, PrioritizeResponse, AuditRow
from api.dependencies import get_service

app = FastAPI(title="Prioritization API", version="1.0.0")

@app.get("/health")
def health() -> dict[str, str]:
    return {"status": "ok"}

@app.post("/prioritize/run", response_model=PrioritizeResponse)
def prioritize_run(payload: PrioritizeRequest) -> PrioritizeResponse:
    service = get_service()

    matching_df = pl.DataFrame([r.model_dump() for r in payload.records])

    audit_df = service.run(matching_df)

    rows = [
        AuditRow(
            tpn_id=row.get("tpn_id"),
            field_name=row.get("field_name"),
            value=row.get("value"),
            winner_source=row.get("winner_source"),
            winner_priority=row.get("winner_priority"),
            normalized_table=row.get("normalized_table"),
        )
        for row in audit_df.to_dicts()
    ]

    return PrioritizeResponse(rows=rows)
