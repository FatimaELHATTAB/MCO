import logging

from domain.task import Task

logger = logging.getLogger(__name__)


class TaskProcessor:
    def __init__(self, task_repository):
        self.task_repository = task_repository

    def run_once(self) -> bool:
        """
        Récupère une tâche MATCHING en PENDING, la passe en PROCESSING,
        exécute le traitement, puis la marque DONE ou FAILED.
        Retourne True si une tâche a été traitée, sinon False.
        """
        task = self.task_repository.claim_next_pending_matching_task()

        if task is None:
            logger.info("Aucune tâche MATCHING en PENDING.")
            return False

        logger.info("Tâche récupérée: row_id=%s payload=%s", task.row_id, task.payload)

        try:
            self.process_task(task)
            self.task_repository.mark_done(task.row_id)
            logger.info("Tâche %s terminée avec succès.", task.row_id)
            return True

        except Exception as exc:
            logger.exception("Erreur sur la tâche %s", task.row_id)
            self.task_repository.mark_failed(task.row_id, str(exc))
            return False

    def process_task(self, task: Task) -> None:
        """
        Logique métier principale.
        """
        job_execution_id = task.job_execution_id
        if job_execution_id is None:
            raise ValueError(f"La tâche {task.row_id} ne contient pas de jobExecutionId.")

        self._run_matching_pipeline(job_execution_id)

    def _run_matching_pipeline(self, job_execution_id: int) -> None:
        """
        Branche ici ta vraie chaîne de traitements.
        """
        logger.info("Lancement du pipeline MATCHING pour jobExecutionId=%s", job_execution_id)

