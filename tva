# lifecycle_impact_repository.py

from enum import Enum


class LifecycleAction(str, Enum):
    UPDATE_MATCHING = "UPDATE_MATCHING"
    DELETE = "DELETE"


class LifecycleImpactRepository:
    def __init__(self, db, schema: str):
        self.db = db
        self.schema = schema

    def resolve_existing_tpn(self, df_updates):
        work_table = self.db.generate_work_table_name("tmp_lifecycle_updates")
        full_work_table = f"{self.schema}.{work_table}"

        self.db.create_work_table_from_df(work_table, df_updates)

        try:
            sql = f"""
            SELECT
                src.*,
                le.tpn_id
            FROM {full_work_table} src
            INNER JOIN {self.schema}.legal_entity le
                ON le.local_id = src.local_id
               AND le.flux_source = src.flux_source
            """
            return self.db.select_df(sql)

        finally:
            self.db.drop_work_table(work_table)

    def load_impacted_clusters(self, df_with_tpn):
        if df_with_tpn is None or len(df_with_tpn) == 0:
            return None

        work_table = self.db.generate_work_table_name("tmp_lifecycle_tpns")
        full_work_table = f"{self.schema}.{work_table}"

        self.db.create_work_table_from_df(work_table, df_with_tpn)

        try:
            sql = f"""
            SELECT DISTINCT
                m.cluster_id
            FROM {self.schema}.matching m
            INNER JOIN {full_work_table} src
                ON m.tpn_id = src.tpn_id
            WHERE m.closed_at IS NULL
              AND m.cluster_id IS NOT NULL
            """
            return self.db.select_df(sql)

        finally:
            self.db.drop_work_table(work_table)

    def load_members_for_replay(self, impacted_clusters_df, replay_sources: list[str]):
        if impacted_clusters_df is None or len(impacted_clusters_df) == 0:
            return None

        work_table = self.db.generate_work_table_name("tmp_lifecycle_clusters")
        full_work_table = f"{self.schema}.{work_table}"

        self.db.create_work_table_from_df(work_table, impacted_clusters_df)

        sources_sql = ", ".join([f"'{source}'" for source in replay_sources])

        try:
            sql = f"""
            SELECT DISTINCT
                m.*
            FROM {self.schema}.matching m
            INNER JOIN {full_work_table} c
                ON m.cluster_id = c.cluster_id
            WHERE m.closed_at IS NULL
              AND m.flux_source IN ({sources_sql})
            """
            return self.db.select_df(sql)

        finally:
            self.db.drop_work_table(work_table)

    def close_matching_for_clusters(self, impacted_clusters_df, action: LifecycleAction):
        if impacted_clusters_df is None or len(impacted_clusters_df) == 0:
            return

        work_table = self.db.generate_work_table_name("tmp_close_clusters")
        full_work_table = f"{self.schema}.{work_table}"

        self.db.create_work_table_from_df(work_table, impacted_clusters_df)

        try:
            sql = f"""
            UPDATE {self.schema}.matching m
            SET
                closed_at = NOW(),
                closed_by = '{action.value}',
                business_validity_to = NOW()
            FROM {full_work_table} c
            WHERE m.cluster_id = c.cluster_id
              AND m.closed_at IS NULL
            """
            self.db.execute(sql)

        finally:
            self.db.drop_work_table(work_table)

    def close_cluster_stats(self, impacted_clusters_df, action: LifecycleAction):
        if impacted_clusters_df is None or len(impacted_clusters_df) == 0:
            return

        work_table = self.db.generate_work_table_name("tmp_close_cluster_stats")
        full_work_table = f"{self.schema}.{work_table}"

        self.db.create_work_table_from_df(work_table, impacted_clusters_df)

        try:
            sql = f"""
            UPDATE {self.schema}.cluster_stats cs
            SET
                closed_at = NOW(),
                closed_by = '{action.value}',
                business_validity_to = NOW()
            FROM {full_work_table} c
            WHERE cs.cluster_id = c.cluster_id
              AND cs.closed_at IS NULL
            """
            self.db.execute(sql)

        finally:
            self.db.drop_work_table(work_table)
